DATABASE_URL="mysql://root:password@127.0.0.1:3306/gongkao_question_bank"
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="http://localhost:3000"

OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
# Use "chat" for OpenAI-compatible gateways that do not support Responses API.
OPENAI_API_MODE="responses"

# Optional automatic mistake analysis after submission.
TUTOR_AUTO_REVIEW_ENABLED="true"
TUTOR_AUTO_REVIEW_MAX_QUESTIONS="10"

# Optional LangSmith tracing for Agent debugging/evaluation.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="gongkao-agent-dev"

# Course knowledge base and Qdrant retrieval.
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="gongkao_course_chunks"
EMBEDDING_BASE_URL=""
EMBEDDING_API_KEY=""
EMBEDDING_MODEL=""
EMBEDDING_DIMENSIONS=""
EMBEDDING_BATCH_SIZE="32"
KNOWLEDGE_RETRIEVAL_TOP_K="8"
KNOWLEDGE_MIN_SCORE="0.35"
